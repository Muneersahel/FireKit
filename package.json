{
  "name": "firekit",
  "version": "0.1.0",
  "description": "Desktop admin for Firebase Firestore and Authentication",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "author": {
    "name": "Munir I Said",
    "email": "saidmunir73@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muneersahel/FireKit.git"
  },
  "homepage": "https://github.com/Muneersahel/FireKit#readme",
  "bugs": {
    "url": "https://github.com/Muneersahel/FireKit/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@parcel/watcher",
      "better-sqlite3",
      "electron",
      "esbuild",
      "keytar",
      "lmdb",
      "msgpackr-extract",
      "protobufjs"
    ]
  },
  "scripts": {
    "ng": "ng",
    "start": "pnpm run electron:dev",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "pnpm run electron:build && concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && node scripts/electron-dev.mjs\"",
    "electron:start": "node scripts/electron-dev.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "dist": "pnpm run build && pnpm run electron:build && electron-builder --publish never",
    "dist:release": "pnpm run build && pnpm run electron:build && electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@angular/cdk": ">=20.0.0 <22.0.0",
    "@angular/common": ">=20.0.0 <22.0.0",
    "@angular/compiler": ">=20.0.0 <22.0.0",
    "@angular/core": ">=20.0.0 <22.0.0",
    "@angular/forms": ">=20.0.0 <22.0.0",
    "@angular/platform-browser": ">=20.0.0 <22.0.0",
    "@angular/router": ">=20.0.0 <22.0.0",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@spartan-ng/brain": "0.0.1-alpha.702",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.0.2",
    "keytar": "^7.9.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": ">=20.0.0 <22.0.0",
    "@angular/cli": ">=20.0.0 <22.0.0",
    "@angular/compiler-cli": ">=20.0.0 <22.0.0",
    "@spartan-ng/cli": "0.0.1-alpha.702",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.firekit.app",
    "productName": "FireKit",
    "publish": null,
    "icon": "build/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "build/icon.icns",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icons/icon.png"
      },
      {
        "from": "build/icon.icns",
        "to": "icons/icon.icns"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "CFBundleName": "FireKit",
        "CFBundleDisplayName": "FireKit"
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "executableName": "FireKit",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "maintainer": "FireKit contributors <muneersahel@users.noreply.github.com>",
      "icon": "build/icons",
      "executableName": "firekit",
      "desktop": {
        "Name": "FireKit",
        "Comment": "Desktop admin for Firebase Firestore and Authentication",
        "StartupWMClass": "FireKit"
      },
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
