{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@spartan-ng/helm/button": ["./libs/ui/button/src/index.ts"],
      "@spartan-ng/helm/utils": ["./libs/ui/utils/src/index.ts"],
      "@spartan-ng/helm/input": ["./libs/ui/input/src/index.ts"],
      "@spartan-ng/helm/textarea": ["./libs/ui/textarea/src/index.ts"],
      "@spartan-ng/helm/select": ["./libs/ui/select/src/index.ts"],
      "@spartan-ng/helm/icon": ["./libs/ui/icon/src/index.ts"],
      "@spartan-ng/helm/table": ["./libs/ui/table/src/index.ts"],
      "@spartan-ng/helm/card": ["./libs/ui/card/src/index.ts"],
      "@spartan-ng/helm/badge": ["./libs/ui/badge/src/index.ts"],
      "@spartan-ng/helm/alert": ["./libs/ui/alert/src/index.ts"],
      "@spartan-ng/helm/scroll-area": ["./libs/ui/scroll-area/src/index.ts"],
      "@spartan-ng/helm/separator": ["./libs/ui/separator/src/index.ts"],
      "@spartan-ng/helm/sidebar": ["./libs/ui/sidebar/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./libs/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./libs/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./libs/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/label": ["./libs/ui/label/src/index.ts"],
      "@spartan-ng/helm/spinner": ["./libs/ui/spinner/src/index.ts"],
      "@spartan-ng/helm/native-select": ["./libs/ui/native-select/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
